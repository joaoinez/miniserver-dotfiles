<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.user.renew-tailscale-certs</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>/Users/miniserver/dotfiles/scripts/renew-tailscale-certs.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true />

    <key>StartInterval</key>
    <integer>7776000</integer>

    <key>StandardOutPath</key>
    <string>/tmp/renew-tailscale-certs.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/renew-tailscale-certs.error.log</string>
  </dict>
</plist>
